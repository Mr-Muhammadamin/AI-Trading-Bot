# === BROKER SETTINGS ===
# Exness MT5 - Your Exness trading account credentials
# Get these from your Exness Personal Area -> Account Settings
EXNESS_ACCOUNT=0
EXNESS_PASSWORD=your_password_here
EXNESS_SERVER=Exness-MT5Trial

# Binance (CCXT) - Optional if using Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
BINANCE_TESTNET=true

# === AI / ML SETTINGS ===
ML_MODEL_PATH=./data/models
USE_XGBOOST=true
USE_LSTM=true
USE_RL_AGENT=true
USE_ENSEMBLE=true

# === TRADING SETTINGS ===
# Supported symbols: XAUUSD (Gold), BTCUSD, ETHUSD, EURUSD, GBPUSD, etc.
# Add 'm' suffix for mini contracts (e.g., XAUUSDm)
SYMBOLS=XAUUSDm
# Timeframes: M1, M5, M15, M30, H1, H4, D1, W1
TIMEFRAMES=M5,M15,H1,H4,D1
MAX_POSITION_SIZE=0.1
MAX_OPEN_TRADES=3
RISK_PER_TRADE=2.0
STOP_LOSS_ATR_MULTIPLIER=1.5
TAKE_PROFIT_ATR_MULTIPLIER=3.0

# === TELEGRAM BOT ===
# Get token from @BotFather on Telegram
# Get chat ID from @userinfobot or @get_id_bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === DATABASE ===
DATABASE_URL=sqlite:///./data/trading.db

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=./logs/trading_bot.log